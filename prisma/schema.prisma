generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  CONTACTED
  SCHEDULED
  CONVERTED
  LOST
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  phone         String
  email         String?
  treatment     String
  preferredDate String?
  source        String?
  status        LeadStatus @default(NEW)
  telecrmSynced Boolean    @default(false)
  telecrmId     String?
  telecrmError  String?
  syncedAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([treatment])
  @@index([telecrmSynced])
}
